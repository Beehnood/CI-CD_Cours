{
  "name": "cicd-form",
  "private": false,
  "version": "0.1.1",
  "type": "module",
  "homepage": "https://beehnood.github.io/CI-CD_Cours/",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build --base=/CI-CD_Cours/",
    "build-npm-ci": "tsc -b && vite build --base=/CI-CD_Cours/",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
    "coverage": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "predeploy": "npm run build",
    "deploy": "node ./node_modules/gh-pages/bin/gh-pages.js -d dist",
    "jsdoc": "node ./node_modules/jsdoc/jsdoc.js -R ./README.md -c ./jsdoc.config.json"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "jsdoc": "^4.0.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
