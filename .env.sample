# GitHub Secrets required by .github/workflows/deploy.yml
# Do not commit real values in this file.

AWS_ACCESS_KEY_ID=replace-with-github-secret
AWS_SECRET_ACCESS_KEY=replace-with-github-secret
AWS_REGION=eu-west-3

# Private Docker registry credentials used by Ansible and Docker login.
REGISTRY_USERNAME=replace-with-registry-user
REGISTRY_PASSWORD=replace-with-registry-password

# MySQL credentials for the deployed form application.
DB_NAME=ynov_ci
DB_PASSWORD=replace-with-db-password

# Admin account created by the Python API.
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=replace-with-admin-password
ADMIN_TOKEN=replace-with-long-random-admin-token

# Optional Terraform variables.
TF_VAR_ALLOWED_SSH_CIDR=0.0.0.0/0
TF_VAR_ALLOWED_APP_CIDR=0.0.0.0/0
TF_VAR_ALLOWED_HTTPS_CIDR=0.0.0.0/0
TF_VAR_INSTANCE_TYPE=t2.micro

# Example files provided for local/manual usage:
# - registry-iac/terraform/terraform.tfvars.example
# - app-iac/terraform/terraform.tfvars.example
# - registry-iac/ansible/inventory.ini.example
# - app-iac/ansible/inventory.ini.example
# - secrets.yml.example
