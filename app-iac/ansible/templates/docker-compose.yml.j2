services:
  database:
    image: "{{ registry_host }}/{{ database_image }}:{{ image_tag }}"
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: "{{ db_password }}"
      MYSQL_DATABASE: "{{ db_name }}"
    volumes:
      - mysql_data:/var/lib/mysql
    healthcheck:
      test: ["CMD-SHELL", "mysqladmin ping -h 127.0.0.1 -uroot -p$${MYSQL_ROOT_PASSWORD} || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

  backend:
    image: "{{ registry_host }}/{{ backend_image }}:{{ image_tag }}"
    restart: unless-stopped
    environment:
      PORT: "8000"
      MYSQL_HOST: database
      MYSQL_PORT: "3306"
      MYSQL_USER: root
      MYSQL_PASSWORD: "{{ db_password }}"
      MYSQL_DATABASE: "{{ db_name }}"
      ADMIN_USERNAME: "{{ admin_username }}"
      ADMIN_PASSWORD: "{{ admin_password }}"
      ADMIN_TOKEN: "{{ admin_token }}"
    ports:
      - "3000:8000"
    depends_on:
      database:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/ready', timeout=3)"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s

  frontend:
    image: "{{ registry_host }}/{{ frontend_image }}:{{ image_tag }}"
    restart: unless-stopped
    ports:
      - "80:80"
    depends_on:
      - backend

  adminer:
    image: adminer:latest
    restart: unless-stopped
    ports:
      - "8080:8080"
    depends_on:
      - database

volumes:
  mysql_data:
